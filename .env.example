# Copie para .env.local e preencha.

# Supabase (projeto → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# IA — apenas servidor (IA metabólica + foto de refeição + interpretação de exames)
# Funciona com OpenAI direto ou qualquer provedor OpenAI-compatible (ex.: OpenRouter).
OPENAI_API_KEY=sk-...
# Para OpenRouter, descomente as duas linhas abaixo:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openai/gpt-4o-mini

# CGM — próximo passo OAuth / SDK (placeholders)
# DEXCOM_CLIENT_ID=
# DEXCOM_CLIENT_SECRET=
# LIBRE_EMAIL=
# LIBRE_PASSWORD=

# Google Fit API (OAuth — próximo passo)
# GOOGLE_FIT_CLIENT_ID=
# GOOGLE_FIT_CLIENT_SECRET=

# Web Push (alarmes de medicação/água/dica do dia) — gere com `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:voce@exemplo.com

# Segredo compartilhado entre pg_cron (Supabase) e as rotas /api/*/dispatch
# deste app — gere um valor aleatório próprio, nunca reaproveite o do
# repositório. Precisa ser o MESMO valor configurado nas funções SQL de
# cron (supabase/migrations/*cron*.sql, *dispatch*.sql).
CRON_SECRET=

# Código de convite exigido para criar conta (controle de acesso do MVP)
SIGNUP_INVITE_CODE=

# Metas de gasto de IA para o relógio no painel /admin (opcional, em US$)
AI_DAILY_BUDGET_USD=1
AI_MONTHLY_BUDGET_USD=20

# Credenciais de app do FreeStyle LibreLinkUp (opcional — sincronização
# automática do CGM). Cada usuário conecta a própria conta pela UI; não
# preencha aqui, é só documentação de que a integração existe.
