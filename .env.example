# Copie para .env.local e preencha.

# Supabase (projeto → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service role — só servidor (cadastro invite-only + cron CGM). Nunca no cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# IA Kimi/Moonshot — apenas servidor (IA metabólica + visão + interpretação)
# Crie a chave em https://platform.moonshot.ai/ e nunca a exponha no cliente.
KIMI_API_KEY=
OPENAI_BASE_URL=https://api.moonshot.ai/v1
AI_MODEL=kimi-k2.6
# Compatibilidade temporária: instalações antigas podem continuar usando
# OPENAI_API_KEY no lugar de KIMI_API_KEY.
# OPENAI_API_KEY=

# Dexcom OAuth (parceiro/sandbox Dexcom Developer)
# DEXCOM_CLIENT_ID=
# DEXCOM_CLIENT_SECRET=
# Redirect registrado no portal Dexcom (ou derive de NEXT_PUBLIC_SITE_URL + /api/cgm/dexcom/callback)
# DEXCOM_REDIRECT_URI=https://seu-dominio/api/cgm/dexcom/callback
# NEXT_PUBLIC_SITE_URL=https://seu-dominio
# DEXCOM_USE_SANDBOX=true
# DEXCOM_API_BASE=https://api.dexcom.com

# Libre — opcional legado (cada usuário conecta pela UI LibreLinkUp)
# LIBRE_EMAIL=
# LIBRE_PASSWORD=

# Google Fit API (OAuth) — projeto no Google Cloud Console com a Fitness
# API ativada. Ver docs/PRODUCAO.md para o passo a passo.
# GOOGLE_FIT_CLIENT_ID=
# GOOGLE_FIT_CLIENT_SECRET=
# Redirect registrado no Google Cloud Console (ou derive de NEXT_PUBLIC_SITE_URL + /api/health/google-fit/callback)
# GOOGLE_FIT_REDIRECT_URI=https://seu-dominio/api/health/google-fit/callback

# Web Push (alarmes de medicação/água/dica do dia) — gere com `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:voce@exemplo.com

# Segredo compartilhado entre pg_cron (Supabase) e as rotas /api/*/dispatch
# deste app — gere um valor aleatório próprio, nunca reaproveite o do
# repositório. Precisa ser o MESMO valor configurado nas funções SQL de
# cron (supabase/migrations/*cron*.sql, *dispatch*.sql).
CRON_SECRET=

# Criptografia das credenciais LibreLinkUp (AES-256). Preferível chave própria
# distinta do CRON_SECRET. Sem esta variável, o app ainda usa CRON_SECRET
# (legado) e remigra no próximo sync bem-sucedido.
CGM_CREDENTIALS_SECRET=

# Código de convite exigido para criar conta (obrigatório — sem isto o
# cadastro fica indisponível). No Supabase Auth, desative "Allow new users
# to sign up": o registro passa por /api/auth/register (service role).
SIGNUP_INVITE_CODE=

# Login social (Google/Apple) cria conta automaticamente no primeiro
# acesso, sem passar pelo SIGNUP_INVITE_CODE — esta é a única barreira
# contra qualquer conta Google/Apple entrar. Lista de e-mails separados
# por vírgula; sem isto, login social nunca autoriza ninguém.
# Configure os provedores em Supabase Dashboard → Authentication →
# Providers (Google: gratuito, só precisa de um OAuth Client no Google
# Cloud Console; Apple: exige Apple Developer Program pago, mais
# trabalhoso — avalie se compensa antes de configurar).
ALLOWED_EMAILS=

# Metas de gasto de IA para o relógio no painel /admin (opcional, em US$)
AI_DAILY_BUDGET_USD=1
AI_MONTHLY_BUDGET_USD=20

# Observabilidade — Sentry (opcional; sem DSN o app só loga no console)
# Crie um projeto em https://sentry.io e cole o DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Upload de source maps no build (opcional)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# Webhook ops (Slack/Discord/etc.) para alertas agregados de cron CGM/push
# OPS_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Credenciais de app do FreeStyle LibreLinkUp (opcional — sincronização
# automática do CGM). Cada usuário conecta a própria conta pela UI; não
# preencha aqui, é só documentação de que a integração existe.
